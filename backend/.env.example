MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=health_system
MAX_CASES_PER_SUBMISSION=100
MAX_SYMPTOMS_PER_SUBMISSION=10
CROSS_VALIDATION_WINDOW_HOURS=24
MAX_CASE_DELTA_RATIO=0.7

# LLM provider config: "ollama" or "gemini"
LLM_PROVIDER=gemini

# Gemini (recommended for cloud inference)
GEMINI_API_KEY=replace_with_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/models

# Ollama fallback/local config
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
